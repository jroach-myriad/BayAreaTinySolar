---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Bay Area Tiny Solar — Off-Grid Energy Coaching</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=DM+Serif+Display:ital@0;1&family=Nunito:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    /* ─── CSS Variables ─────────────────────────────────── */
    :root {
      --sun:       #E8973A;
      --sun-light: #F4C06A;
      --terracotta:#C1633A;
      --soil:      #5C3D2E;
      --forest:    #3A5C3D;
      --forest-lt: #5C8A5F;
      --sage:      #A8BC9A;
      --cream:     #FAF5EC;
      --parchment: #F0E8D6;
      --stone:     #D6CAB8;
      --ink:       #2C2417;
      --mist:      #EDE8DF;
    }

    /* ─── Reset & Base ──────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Nunito', sans-serif;
      background: var(--cream);
      color: var(--ink);
      overflow-x: hidden;
    }
    h1, h2, h3 { font-family: 'DM Serif Display', serif; }
    p { font-family: 'Lora', serif; line-height: 1.75; }
    a { text-decoration: none; color: inherit; }
    img { display: block; width: 100%; object-fit: cover; }

    /* ─── Noise Texture Overlay ─────────────────────────── */
    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none; z-index: 9999; opacity: 0.4;
    }

    /* ─── Nav ───────────────────────────────────────────── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.2rem 3rem;
      background: rgba(250, 245, 236, 0.88);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--stone);
      transition: box-shadow 0.3s;
    }
    nav.scrolled { box-shadow: 0 2px 20px rgba(92,61,46,0.1); }
    .nav-logo {
      display: flex; align-items: center; gap: 0.6rem;
    }
    .nav-logo .sun-icon {
      width: 36px; height: 36px;
    }
    .nav-logo span {
      font-family: 'DM Serif Display', serif;
      font-size: 1.2rem;
      color: var(--soil);
      line-height: 1.1;
    }
    .nav-logo span em {
      display: block;
      font-style: italic;
      font-size: 0.75rem;
      color: var(--terracotta);
      letter-spacing: 0.05em;
    }
    .nav-links {
      display: flex; gap: 2rem; align-items: center;
      list-style: none;
    }
    .nav-links a {
      font-family: 'Nunito', sans-serif;
      font-weight: 600;
      font-size: 0.9rem;
      color: var(--soil);
      letter-spacing: 0.02em;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--terracotta); }
    .nav-cta {
      background: var(--terracotta);
      color: var(--cream) !important;
      padding: 0.55rem 1.3rem;
      border-radius: 100px;
      transition: background 0.2s, transform 0.15s !important;
    }
    .nav-cta:hover { background: var(--soil) !important; transform: translateY(-1px); }

    /* ─── Hero ──────────────────────────────────────────── */
    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      padding-top: 80px;
      background: var(--parchment);
      position: relative;
      overflow: hidden;
    }
    .hero::after {
      content: '';
      position: absolute;
      bottom: -2px; left: 0; right: 0; height: 80px;
      background: var(--cream);
      clip-path: ellipse(55% 100% at 50% 100%);
    }
    /* decorative sun rays */
    .hero-sun-bg {
      position: absolute;
      top: -10%; right: -5%;
      width: 60vw; height: 60vw;
      background: radial-gradient(circle, var(--sun-light) 0%, rgba(244,192,106,0.15) 50%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
      animation: pulse-sun 6s ease-in-out infinite;
    }
    @keyframes pulse-sun {
      0%, 100% { transform: scale(1); opacity: 0.7; }
      50%       { transform: scale(1.05); opacity: 1; }
    }
    .hero-text {
      display: flex; flex-direction: column; justify-content: center;
      padding: 5rem 3rem 5rem 5rem;
      position: relative; z-index: 2;
    }
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-family: 'Nunito', sans-serif;
      font-size: 0.78rem; font-weight: 600;
      letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--forest);
      margin-bottom: 1.2rem;
    }
    .hero-eyebrow::before {
      content: '';
      display: block; width: 28px; height: 2px;
      background: var(--forest);
    }
    h1.hero-title {
      font-size: clamp(2.8rem, 4.5vw, 4.2rem);
      line-height: 1.1;
      color: var(--soil);
      margin-bottom: 1.4rem;
    }
    h1.hero-title em {
      color: var(--terracotta);
      font-style: italic;
    }
    .hero-subtitle {
      font-size: 1.05rem;
      color: #5C4A38;
      max-width: 440px;
      margin-bottom: 2.4rem;
    }
    .hero-actions {
      display: flex; gap: 1rem; flex-wrap: wrap;
    }
    .btn-primary {
      background: var(--terracotta);
      color: var(--cream);
      padding: 0.85rem 2rem;
      border-radius: 100px;
      font-family: 'Nunito', sans-serif;
      font-weight: 700; font-size: 0.95rem;
      border: none; cursor: pointer;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
      box-shadow: 0 4px 20px rgba(193,99,58,0.3);
    }
    .btn-primary:hover {
      background: var(--soil);
      transform: translateY(-2px);
      box-shadow: 0 6px 28px rgba(92,61,46,0.3);
    }
    .btn-secondary {
      background: transparent;
      color: var(--soil);
      padding: 0.85rem 2rem;
      border-radius: 100px;
      font-family: 'Nunito', sans-serif;
      font-weight: 700; font-size: 0.95rem;
      border: 2px solid var(--stone);
      cursor: pointer;
      transition: border-color 0.2s, color 0.2s, transform 0.15s;
    }
    .btn-secondary:hover {
      border-color: var(--terracotta);
      color: var(--terracotta);
      transform: translateY(-2px);
    }
    .hero-stats {
      display: flex; gap: 2.5rem;
      margin-top: 3rem;
      padding-top: 2rem;
      border-top: 1px solid var(--stone);
    }
    .stat-num {
      font-family: 'DM Serif Display', serif;
      font-size: 2rem; color: var(--terracotta);
    }
    .stat-label {
      font-family: 'Nunito', sans-serif;
      font-size: 0.8rem; font-weight: 600;
      color: var(--soil); opacity: 0.7;
      text-transform: uppercase; letter-spacing: 0.05em;
    }
    .hero-image {
      position: relative; z-index: 2;
      display: flex; align-items: center; padding: 4rem 4rem 4rem 2rem;
    }
    .hero-img-frame {
      width: 100%;
      aspect-ratio: 4/5;
      border-radius: 40% 60% 55% 45% / 45% 45% 55% 55%;
      overflow: hidden;
      background: var(--stone);
      box-shadow: 0 30px 80px rgba(92,61,46,0.2);
      position: relative;
      animation: float 7s ease-in-out infinite;
    }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50%       { transform: translateY(-12px); }
    }
    .img-placeholder {
      width: 100%; height: 100%;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: 0.75rem;
      background: linear-gradient(135deg, var(--sage) 0%, var(--stone) 100%);
      color: var(--soil); opacity: 0.7;
      font-family: 'Nunito', sans-serif; font-size: 0.85rem; font-weight: 600;
    }
    .img-placeholder svg { opacity: 0.5; }
    .hero-badge {
      position: absolute;
      bottom: 12%; left: -18%;
      background: var(--cream);
      border-radius: 16px;
      padding: 0.9rem 1.3rem;
      box-shadow: 0 10px 40px rgba(92,61,46,0.15);
      display: flex; align-items: center; gap: 0.75rem;
      border: 1px solid var(--stone);
      animation: float 7s ease-in-out infinite;
      animation-delay: -3s;
    }
    .badge-icon {
      width: 42px; height: 42px;
      border-radius: 12px;
      background: var(--sun-light);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.4rem;
    }
    .badge-text strong {
      display: block;
      font-family: 'DM Serif Display', serif;
      font-size: 1rem; color: var(--soil);
    }
    .badge-text span {
      font-size: 0.75rem; color: var(--forest); font-weight: 600;
    }

    /* ─── Section Shared ────────────────────────────────── */
    section { position: relative; }
    .section-inner {
      max-width: 1140px;
      margin: 0 auto;
      padding: 6rem 2rem;
    }
    .section-label {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-family: 'Nunito', sans-serif;
      font-size: 0.75rem; font-weight: 700;
      letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--terracotta);
      margin-bottom: 1rem;
    }
    .section-label::before {
      content: ''; display: block;
      width: 20px; height: 2px; background: var(--terracotta);
    }
    h2.section-title {
      font-size: clamp(2rem, 3.5vw, 3rem);
      color: var(--soil);
      line-height: 1.15;
      margin-bottom: 1.2rem;
    }
    h2.section-title em { color: var(--terracotta); font-style: italic; }

    /* ─── About ─────────────────────────────────────────── */
    .about { background: var(--cream); }
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }
    .about-img-wrap {
      position: relative;
    }
    .about-img-main {
      width: 100%;
      aspect-ratio: 3/4;
      border-radius: 12px 48px 12px 48px;
      overflow: hidden;
      background: var(--stone);
    }
    .about-img-accent {
      position: absolute;
      bottom: -8%; right: -8%;
      width: 55%;
      aspect-ratio: 1;
      border-radius: 48px 12px 48px 12px;
      overflow: hidden;
      background: var(--parchment);
      border: 4px solid var(--cream);
      box-shadow: 0 10px 40px rgba(92,61,46,0.12);
    }
    .about-body p + p { margin-top: 1rem; }
    .about-body p { color: #5C4A38; }
    .about-highlights {
      display: flex; flex-direction: column; gap: 1rem;
      margin-top: 2rem;
    }
    .highlight-item {
      display: flex; gap: 1rem; align-items: flex-start;
    }
    .highlight-dot {
      width: 10px; height: 10px; border-radius: 50%;
      background: var(--sun);
      flex-shrink: 0; margin-top: 6px;
    }
    .highlight-item p {
      font-size: 0.95rem; color: var(--soil); margin: 0;
    }
    .highlight-item strong { color: var(--terracotta); }

    /* ─── Services ──────────────────────────────────────── */
    .services { background: var(--parchment); }
    .services::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 80px;
      background: var(--cream);
      clip-path: ellipse(55% 100% at 50% 0%);
    }
    .services::after {
      content: '';
      position: absolute; bottom: 0; left: 0; right: 0; height: 80px;
      background: var(--cream);
      clip-path: ellipse(55% 100% at 50% 100%);
    }
    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      margin-top: 3rem;
    }
    .service-card {
      background: var(--cream);
      border-radius: 20px;
      padding: 2.5rem 2rem;
      border: 1px solid var(--stone);
      position: relative;
      overflow: hidden;
      transition: transform 0.25s, box-shadow 0.25s;
    }
    .service-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 60px rgba(92,61,46,0.12);
    }
    .service-card::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 4px;
      background: var(--sun);
    }
    .service-card:nth-child(2)::before { background: var(--forest-lt); }
    .service-card:nth-child(3)::before { background: var(--terracotta); }
    .service-icon {
      width: 56px; height: 56px;
      border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.8rem;
      margin-bottom: 1.4rem;
    }
    .service-card:nth-child(1) .service-icon { background: rgba(232,151,58,0.15); }
    .service-card:nth-child(2) .service-icon { background: rgba(92,138,95,0.15); }
    .service-card:nth-child(3) .service-icon { background: rgba(193,99,58,0.15); }
    .service-card h3 {
      font-size: 1.3rem; color: var(--soil);
      margin-bottom: 0.75rem;
    }
    .service-card p {
      font-size: 0.92rem; color: #5C4A38;
      line-height: 1.7;
      margin-bottom: 1.5rem;
    }
    .service-card-img {
      width: 100%;
      aspect-ratio: 16/9;
      border-radius: 10px;
      overflow: hidden;
      background: var(--mist);
      margin-bottom: 1.5rem;
    }
    .service-link {
      display: inline-flex; align-items: center; gap: 0.4rem;
      font-family: 'Nunito', sans-serif;
      font-weight: 700; font-size: 0.85rem;
      color: var(--terracotta);
      transition: gap 0.2s;
    }
    .service-link:hover { gap: 0.7rem; }
    .service-card:nth-child(2) .service-link { color: var(--forest); }

    /* ─── How It Works ───────────────────────────────────── */
    .process { background: var(--cream); }
    .process-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
      margin-top: 3rem;
      position: relative;
    }
    .process-grid::before {
      content: '';
      position: absolute;
      top: 36px; left: 12.5%; right: 12.5%; height: 2px;
      background: repeating-linear-gradient(90deg, var(--stone) 0, var(--stone) 8px, transparent 8px, transparent 16px);
    }
    .process-step {
      display: flex; flex-direction: column; align-items: center;
      text-align: center;
      padding: 1.5rem 1rem;
    }
    .step-num {
      width: 72px; height: 72px;
      border-radius: 50%;
      background: var(--parchment);
      border: 2px solid var(--stone);
      display: flex; align-items: center; justify-content: center;
      font-family: 'DM Serif Display', serif;
      font-size: 1.6rem;
      color: var(--terracotta);
      margin-bottom: 1.2rem;
      position: relative; z-index: 1;
      transition: background 0.25s, border-color 0.25s;
    }
    .process-step:hover .step-num {
      background: var(--terracotta);
      border-color: var(--terracotta);
      color: var(--cream);
    }
    .process-step h3 {
      font-size: 1.05rem; color: var(--soil);
      margin-bottom: 0.5rem;
    }
    .process-step p {
      font-size: 0.88rem; color: #7A6455;
    }

    /* ─── Gallery strip ─────────────────────────────────── */
    .gallery-strip {
      background: var(--parchment);
      padding: 3rem 0;
      overflow: hidden;
    }
    .gallery-track {
      display: flex; gap: 1.5rem;
      animation: scroll-gallery 30s linear infinite;
      width: max-content;
    }
    .gallery-track:hover { animation-play-state: paused; }
    @keyframes scroll-gallery {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    .gallery-item {
      width: 260px; height: 190px;
      border-radius: 16px;
      overflow: hidden;
      background: var(--stone);
      flex-shrink: 0;
    }

    /* ─── Testimonials ──────────────────────────────────── */
    .testimonials { background: var(--forest); padding: 6rem 2rem; }
    .testimonials .section-label { color: var(--sage); }
    .testimonials .section-label::before { background: var(--sage); }
    .testimonials h2.section-title { color: var(--cream); }
    .testimonials h2.section-title em { color: var(--sun-light); }
    .t-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 3rem;
    }
    .t-card {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 16px;
      padding: 2rem;
      transition: background 0.25s;
    }
    .t-card:hover { background: rgba(255,255,255,0.1); }
    .t-stars { color: var(--sun-light); font-size: 1rem; margin-bottom: 1rem; letter-spacing: 2px; }
    .t-card p {
      font-size: 0.95rem; color: rgba(250,245,236,0.85);
      line-height: 1.7; margin-bottom: 1.5rem;
    }
    .t-author {
      display: flex; align-items: center; gap: 0.75rem;
    }
    .t-avatar {
      width: 42px; height: 42px; border-radius: 50%;
      overflow: hidden; background: var(--stone);
      flex-shrink: 0;
    }
    .t-name {
      font-family: 'Nunito', sans-serif;
      font-weight: 700; font-size: 0.9rem;
      color: var(--cream);
    }
    .t-location {
      font-family: 'Nunito', sans-serif;
      font-size: 0.78rem; color: var(--sage);
    }

    /* ─── Contact ───────────────────────────────────────── */
    .contact { background: var(--cream); }
    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1.3fr;
      gap: 5rem;
      align-items: start;
    }
    .contact-info h2 { margin-bottom: 1rem; }
    .contact-info p { color: #5C4A38; margin-bottom: 2rem; }
    .contact-details {
      display: flex; flex-direction: column; gap: 1.2rem;
      margin-top: 2rem;
    }
    .contact-detail-item {
      display: flex; align-items: center; gap: 1rem;
    }
    .detail-icon {
      width: 44px; height: 44px;
      border-radius: 12px;
      background: var(--parchment);
      border: 1px solid var(--stone);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem;
      flex-shrink: 0;
    }
    .detail-text strong {
      display: block;
      font-family: 'Nunito', sans-serif;
      font-size: 0.8rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--soil); opacity: 0.6;
    }
    .detail-text span {
      font-family: 'Lora', serif;
      font-size: 0.95rem; color: var(--soil);
    }
    /* Form */
    .contact-form {
      background: var(--parchment);
      border-radius: 24px;
      padding: 2.5rem;
      border: 1px solid var(--stone);
    }
    .contact-form h3 {
      font-size: 1.4rem; color: var(--soil);
      margin-bottom: 1.5rem;
    }
    .form-row {
      display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
      margin-bottom: 1rem;
    }
    .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
    .form-group.full { grid-column: 1 / -1; }
    label {
      font-family: 'Nunito', sans-serif;
      font-size: 0.8rem; font-weight: 700;
      color: var(--soil); letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    input, textarea, select {
      background: var(--cream);
      border: 1.5px solid var(--stone);
      border-radius: 10px;
      padding: 0.75rem 1rem;
      font-family: 'Lora', serif; font-size: 0.95rem;
      color: var(--ink);
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
      width: 100%;
    }
    input:focus, textarea:focus, select:focus {
      border-color: var(--terracotta);
      box-shadow: 0 0 0 3px rgba(193,99,58,0.12);
    }
    textarea { resize: vertical; min-height: 130px; }
    .form-interest {
      display: flex; flex-wrap: wrap; gap: 0.6rem;
      margin-bottom: 1.5rem;
    }
    .interest-chip {
      background: var(--cream);
      border: 1.5px solid var(--stone);
      border-radius: 100px;
      padding: 0.4rem 1rem;
      font-family: 'Nunito', sans-serif;
      font-size: 0.82rem; font-weight: 600;
      color: var(--soil); cursor: pointer;
      transition: background 0.2s, border-color 0.2s, color 0.2s;
      user-select: none;
    }
    .interest-chip:hover,
    .interest-chip.active {
      background: var(--terracotta);
      border-color: var(--terracotta);
      color: var(--cream);
    }
    .form-submit {
      width: 100%;
      background: var(--terracotta);
      color: var(--cream);
      padding: 1rem;
      border-radius: 100px;
      font-family: 'Nunito', sans-serif;
      font-weight: 700; font-size: 1rem;
      border: none; cursor: pointer;
      transition: background 0.2s, transform 0.15s;
      box-shadow: 0 4px 20px rgba(193,99,58,0.25);
    }
    .form-submit:hover {
      background: var(--soil);
      transform: translateY(-2px);
    }
    .form-note {
      text-align: center;
      font-family: 'Nunito', sans-serif;
      font-size: 0.78rem; color: #9A8878;
      margin-top: 0.75rem;
    }

    /* ─── Footer ────────────────────────────────────────── */
    footer {
      background: var(--soil);
      color: var(--parchment);
